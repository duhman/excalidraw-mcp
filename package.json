{
  "name": "excalidraw-mcp",
  "version": "0.1.0",
  "description": "Full-capability Excalidraw MCP server with hybrid JSON + browser engines",
  "main": "dist/src/index.js",
  "scripts": {
    "build:excalidraw-node-api": "node scripts/build-excalidraw-node-api.mjs",
    "sync:runtime-assets": "node scripts/sync-runtime-assets.mjs",
    "build": "npm run build:excalidraw-node-api && tsc -p tsconfig.json && npm run sync:runtime-assets",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "test": "npm run build && vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "start:stdio": "node dist/src/index.js --transport stdio",
    "start:http": "node dist/src/index.js --transport http",
    "dev:http": "tsx src/index.ts --transport http",
    "smoke:dist": "node scripts/dist-stdio-smoke.mjs",
    "smoke:account:plus": "node scripts/account-live-smoke.mjs plus",
    "smoke:account:excalidraw": "node scripts/account-live-smoke.mjs excalidraw",
    "typecheck": "npm run build:excalidraw-node-api && tsc -p tsconfig.json --noEmit",
    "postinstall": "node scripts/fix-roughjs-import.mjs && node scripts/build-excalidraw-node-api.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "private": true,
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mime": "^4.1.0",
    "p-limit": "^7.3.0",
    "playwright": "^1.58.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
